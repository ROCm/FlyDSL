"""MLA (Multi-Latent Attention) decode kernel for FlyDSL.

Optimized for short query sequences (seqlen_q <= 4) with GQA.
Implements absorbed MLA where the KV cache stores [c_kv || k_rope] per token.

Key design:
- MFMA 16x16x16f16 for both GEMM stages.
- 4 waves per workgroup, each wave handles one seqlen_q position.
  Each MFMA tile computes 16 Q heads simultaneously (lane_mod_16 = head).
- No if-else boundary checks for KV loads (assumes seqlen_kv % BLOCK_N == 0).
- Online softmax in registers; P kept in registers for direct GEMM2 feed.
- Three LDS buffers: two for K (double-buffered prefetch), one for V^T.
  V is NOT reloaded from global memory — it is read directly from the
  current K buffer in LDS (since c_kv serves as both K_nope and V),
  transposed in registers, and written to the V^T buffer.
- BLOCK_N=16 to fit all three buffers within 64 KB LDS.
- Paged KV cache via block_table: logical KV positions are mapped to
  physical blocks through a per-batch block table (i32 indices).

GEMM1: S = K @ Q^T   using HEAD_DIM_QK = kv_lora_rank + qk_rope_head_dim
GEMM2: O^T = V^T @ P  using HEAD_DIM_V  = kv_lora_rank

Layout (1D flattened):
  Q       : [batch, seqlen_q,  num_q_heads,  HEAD_DIM_QK]
  KV      : [num_physical_blocks, page_block_size, num_kv_heads, HEAD_DIM_QK]
  Mid_O   : [batch*seqlen_q, num_kv_splits, num_q_heads, HEAD_DIM_V]  (fp32)
  Mid_lse : [batch*seqlen_q, num_kv_splits, num_q_heads]              (fp32)
  block_table : [batch, max_num_blocks]   (i32 physical block ids)

KV split mode:
  The KV sequence is partitioned into num_kv_splits contiguous chunks.
  Each split produces normalised partial output (fp32) and log-sum-exp
  (lse = m + log(l)), compatible with the stage-2 combine kernel that
  merges splits via online log-sum-exp.

Grid:  (batch, num_head_groups, num_kv_splits)  -- num_head_groups = nhead/16
Block: (256,) -- 4 waves of 64, each wave handles one seqlen_q row

LDS layout (f16 element offsets):
  K_buf_0 : [0,                     K_BUF_ELEMS)
  K_buf_1 : [K_BUF_ELEMS,           2*K_BUF_ELEMS)
  V^T_buf : [2*K_BUF_ELEMS,         2*K_BUF_ELEMS + VT_BUF_ELEMS)

Requires: kv_lora_rank % 16 == 0, qk_rope_head_dim % 16 == 0,
          GQA group size >= 4, seqlen_kv % BLOCK_N == 0,
          page_block_size % BLOCK_N == 0, page_block_size <= 64.
"""

import math

import flydsl.compiler as flyc
import flydsl.expr as fx
from flydsl.compiler.kernel_function import CompilationContext

from flydsl.expr import range_constexpr, const_expr
from flydsl.runtime.device import get_rocm_arch as get_hip_arch
from flydsl.utils.smem_allocator import SmemAllocator, SmemPtr

from flydsl._mlir import ir
from flydsl._mlir.dialects import llvm
from flydsl._mlir.dialects import memref as memref_dialect
from flydsl._mlir.dialects import math as std_math
from flydsl._mlir.dialects import vector as _vector
from flydsl._mlir.dialects import fly as _fly

from flydsl.expr import arith, vector, gpu, buffer_ops, rocdl
from flydsl.expr.arith import _to_raw as _raw
from flydsl.expr.typing import T


KERNEL_NAME = "mla_decode_kernel"


# ---------------------------------------------------------------------------
# Helpers not present in the new vector module
# ---------------------------------------------------------------------------

def _vec_shuffle(a, b, mask):
    """vector.shuffle returning ArithValue."""
    return _vector.ShuffleOp(_raw(a), _raw(b), mask).result


def _vec_broadcast(result_type, source):
    """vector.broadcast returning ArithValue."""
    return _vector.BroadcastOp(result_type, _raw(source)).result


def _s_waitcnt(vmcnt=None, expcnt=None, lgkmcnt=None):
    """Emit s_waitcnt with gfx9 bitfield encoding.

    gfx9/gfx94x layout:
      vmcnt[3:0]   = bits [3:0]
      expcnt[2:0]  = bits [6:4]
      lgkmcnt[3:0] = bits [11:8]
      vmcnt[5:4]   = bits [15:14]
    Unspecified counters default to max (no wait).
    """
    vm = 63 if vmcnt is None else vmcnt
    exp = 7 if expcnt is None else expcnt
    lgkm = 15 if lgkmcnt is None else lgkmcnt
    vm_lo = vm & 0xF
    vm_hi = (vm >> 4) & 0x3
    bf = (vm_hi << 14) | ((lgkm & 0xF) << 8) | ((exp & 0x7) << 4) | vm_lo
    rocdl.s_waitcnt(bf)


def _create_llvm_ptr(value, address_space=0):
    """Convert an integer/index value to LLVM pointer."""
    v = _raw(value)
    if isinstance(v.type, ir.IndexType):
        v = arith.IndexCastOp(T.i64, v).result
    if address_space == 0:
        ptr_type = ir.Type.parse('!llvm.ptr')
    else:
        ptr_type = ir.Type.parse(f'!llvm.ptr<{address_space}>')
    return llvm.IntToPtrOp(ptr_type, v).result


def _set_mfma_vgpr_form():
    """Force MFMA to use ACC_CD=0 (D/C in ArchVGPR) via LLVM cl::opt.

    This allows MFMA src_b to reside in AccVGPR (e.g. Q loaded via
    ds_read with ACC=1) while keeping the accumulator in ArchVGPR,
    avoiding the register-class cascade that inflates agpr_count.
    """
    import ctypes
    import os
    lib_dir = os.path.dirname(
        __import__('flydsl._mlir._mlir_libs', fromlist=['_mlir_libs']).__file__
    )
    lib = ctypes.CDLL(os.path.join(lib_dir, 'libFlyPythonCAPI.so'))
    parse_fn = lib.LLVMParseCommandLineOptions
    parse_fn.restype = None
    parse_fn.argtypes = [
        ctypes.c_int,
        ctypes.POINTER(ctypes.c_char_p),
        ctypes.c_char_p,
    ]
    argv = [b'mlir', b'-amdgpu-mfma-vgpr-form']
    argv_arr = (ctypes.c_char_p * len(argv))(*argv)
    parse_fn(len(argv), argv_arr, None)


_set_mfma_vgpr_form()


def compile_mla_decode(
    num_q_heads=16,
    num_kv_heads=1,
    kv_lora_rank=512,
    qk_rope_head_dim=64,
    page_block_size=64,
    causal=True,
    dtype_str="f16",
    sm_scale=None,
):
    gpu_arch = get_hip_arch()

    BLOCK_N = 16
    NUM_WAVES = 4
    WARP_SIZE = 64
    BLOCK_SIZE = NUM_WAVES * WARP_SIZE
    HEADS_PER_WAVE = 16

    NUM_Q_HEADS = num_q_heads
    NUM_KV_HEADS = num_kv_heads
    HEAD_DIM_QK = kv_lora_rank + qk_rope_head_dim
    HEAD_DIM_V = kv_lora_rank
    GQA_GROUP = NUM_Q_HEADS // NUM_KV_HEADS
    NUM_HEAD_GROUPS = NUM_Q_HEADS // HEADS_PER_WAVE
    CAUSAL = causal
    PAGE_BLOCK_SIZE = page_block_size

    assert NUM_Q_HEADS % HEADS_PER_WAVE == 0
    assert GQA_GROUP >= HEADS_PER_WAVE
    assert HEAD_DIM_V % 16 == 0
    assert qk_rope_head_dim % 16 == 0
    assert dtype_str == "f16"
    assert PAGE_BLOCK_SIZE % BLOCK_N == 0, (
        f"page_block_size ({PAGE_BLOCK_SIZE}) must be a multiple of BLOCK_N ({BLOCK_N})"
    )
    assert PAGE_BLOCK_SIZE <= 64, (
        f"page_block_size ({PAGE_BLOCK_SIZE}) must be <= 64"
    )

    if sm_scale is None:
        sm_scale = 1.0 / math.sqrt(HEAD_DIM_QK)

    K_STEPS = HEAD_DIM_QK // 32
    N_KV_SUBTILES = BLOCK_N // 16  # 1
    D_CHUNKS = HEAD_DIM_V // 16
    PV_K_STEPS = N_KV_SUBTILES     # 1

    STRIDE_TOKEN_Q = NUM_Q_HEADS * HEAD_DIM_QK
    STRIDE_TOKEN_KV = NUM_KV_HEADS * HEAD_DIM_QK
    STRIDE_PAGE = PAGE_BLOCK_SIZE * STRIDE_TOKEN_KV

    K_STRIDE = (
        (HEAD_DIM_QK + 2 * WARP_SIZE - 1)
        // (2 * WARP_SIZE) * (2 * WARP_SIZE)
    )
    VT_STRIDE = (BLOCK_N // 4) * 8

    # ---- LDS buffer sizes (f16 elements) ----
    K_BUF_ELEMS = BLOCK_N * K_STRIDE
    VT_BUF_ELEMS = (HEAD_DIM_V // 2) * VT_STRIDE
    VT_BUF_OFFSET = 2 * K_BUF_ELEMS
    KV_LDS_SIZE = 2 * K_BUF_ELEMS + VT_BUF_ELEMS

    # ---- Per-wave K cooperative load ----
    K_CALLS_PER_ROW = K_STRIDE // (2 * WARP_SIZE)
    K_ROWS_PER_WAVE = BLOCK_N // NUM_WAVES

    # ---- Q preload buffer (64x64 tiled, overlaps LDS before K/V phase) ----
    MAX_SEQLEN_Q = 4
    Q_TILE_DIM = 64
    Q_TILE_ROWS = MAX_SEQLEN_Q * HEADS_PER_WAVE
    Q_DIM_TILES = HEAD_DIM_QK // Q_TILE_DIM
    Q_TILE_ELEMS = Q_TILE_ROWS * Q_TILE_DIM
    assert HEAD_DIM_QK % Q_TILE_DIM == 0, (
        f"HEAD_DIM_QK ({HEAD_DIM_QK}) must be a multiple of Q_TILE_DIM ({Q_TILE_DIM})"
    )
    Q_CALLS_PER_WAVE = HEADS_PER_WAVE // 2
    Q_MAX_BATCH = KV_LDS_SIZE // Q_TILE_ELEMS

    LDS_SIZE = max(KV_LDS_SIZE, Q_TILE_ELEMS)

    # ---- V^T transpose: [dim/2, seqlen/4, 2, 4] layout ----
    assert HEAD_DIM_V // 2 == BLOCK_SIZE

    # Pre-build K load inline asm string (pure Python, no MLIR)
    _kload_lines = []
    for _r in range(K_ROWS_PER_WAVE):
        _m0off = _r * K_STRIDE * 2
        if _r == 0:
            _kload_lines.append("s_mov_b32 m0, $2")
        else:
            _kload_lines.append("s_add_i32 m0, $2, " + hex(_m0off))
        _kload_lines.append("s_nop 0")
        _soff = "0" if _r == 0 else ("$" + str(_r + 2))
        for _j in range(K_CALLS_PER_ROW):
            _off = "" if _j == 0 else (
                " offset:" + str(_j * 2 * WARP_SIZE * 2))
            _kload_lines.append(
                "buffer_load_dword $1, $0, "
                + _soff + " offen" + _off + " sc0 lds")
    _KLOAD_ASM = "\n".join(_kload_lines)
    _KLOAD_CONSTRAINTS = ",".join(
        ["s", "v", "s"]
        + ["s"] * (K_ROWS_PER_WAVE - 1)
        + ["~{m0}"])

    # ---- SmemAllocator setup (new API) ----
    allocator_pong = SmemAllocator(None, arch=gpu_arch, global_sym_name="smem0")
    allocator_ping = SmemAllocator(None, arch=gpu_arch, global_sym_name="smem1")
    allocator_vt = SmemAllocator(None, arch=gpu_arch, global_sym_name="smemvt")
    allocator_red = SmemAllocator(None, arch=gpu_arch, global_sym_name="smem_red")

    # f16 = 2 bytes per element
    lds_k_cur_offset = allocator_pong._align(allocator_pong.ptr, 2)
    allocator_pong.ptr = lds_k_cur_offset + K_BUF_ELEMS * 2

    lds_k_next_offset = allocator_ping._align(allocator_ping.ptr, 2)
    allocator_ping.ptr = lds_k_next_offset + K_BUF_ELEMS * 2

    lds_vt_offset = allocator_vt._align(allocator_vt.ptr, 2)
    allocator_vt.ptr = lds_vt_offset + VT_BUF_ELEMS * 2

    lds_red_offset = allocator_red._align(allocator_red.ptr, 4)
    allocator_red.ptr = lds_red_offset + 256 * 4

    # ---- Kernel function ----
    @flyc.kernel
    def mla_decode_kernel(
        Q: fx.Tensor,
        KV: fx.Tensor,
        Mid_O: fx.Tensor,
        Mid_lse: fx.Tensor,
        block_table: fx.Tensor,
        batch_size: fx.Int32,
        seqlen_q: fx.Int32,
        kv_indptr: fx.Tensor,
        max_num_blocks: fx.Int32,
        num_kv_splits: fx.Int32,
    ):
        compute_type = T.f32
        elem_type = T.f16
        fm_fast = arith.FastMathFlags.fast

        v4f16_type = ir.VectorType.get([4], elem_type)
        v4f32_type = ir.VectorType.get([4], compute_type)
        v8f16_type = ir.VectorType.get([8], elem_type)
        i32_type = T.i32
        v2f16_type = ir.VectorType.get([2], elem_type)
        v1i32_type = ir.VectorType.get([1], i32_type)
        i64_type = T.i64

        # Cast i32 kernel args to index
        seqlen_q_v = arith.index_cast(T.index, seqlen_q.ir_value())
        max_num_blocks_v = arith.index_cast(T.index, max_num_blocks.ir_value())
        batch_size_v = arith.index_cast(T.index, batch_size.ir_value())

        # ---- LDS buffers ----
        base_ptr = allocator_pong.get_base()
        base_ptr1 = allocator_ping.get_base()
        base_ptr_vt = allocator_vt.get_base()
        base_ptr_red = allocator_red.get_base()

        lds_k_cur_buf = SmemPtr(
            base_ptr, lds_k_cur_offset, T.f16,
            shape=(K_BUF_ELEMS,),
        ).get()
        lds_k_next_buf = SmemPtr(
            base_ptr1, lds_k_next_offset, T.f16,
            shape=(K_BUF_ELEMS,),
        ).get()
        lds_vt = SmemPtr(
            base_ptr_vt, lds_vt_offset, T.f16,
            shape=(VT_BUF_ELEMS,),
        ).get()
        lds_red = SmemPtr(
            base_ptr_red, lds_red_offset, T.f32,
            shape=(256,),
        ).get()

        # ---- Thread / block indices ----
        batch_idx = gpu.block_id("x")
        ptr_llvm = _fly.extract_aligned_pointer_as_index(
            ir.Type.parse('!llvm.ptr'), kv_indptr.value)
        base_ptr_i64 = llvm.PtrToIntOp(i64_type, ptr_llvm).result
        batch_byte_off = arith.index_cast(
            i32_type, batch_idx * 4)
        v2i32_kv = ir.VectorType.get([2], i32_type)
        asm_op = llvm.InlineAsmOp(
            v2i32_kv,
            [_raw(base_ptr_i64), _raw(batch_byte_off)],
            "s_load_dwordx2 $0, $1, $2\ns_waitcnt lgkmcnt(0)",
            "=s,s,s",
            has_side_effects=False,
            is_align_stack=False,
        )
        kv_pair = asm_op.res
        kv_start_i32 = vector.extract(
            kv_pair, static_position=[0], dynamic_position=[])
        kv_end_i32 = vector.extract(
            kv_pair, static_position=[1], dynamic_position=[])
        kv_len_i32 = arith.SubIOp(_raw(kv_end_i32), _raw(kv_start_i32)).result
        seqlen_kv_v = arith.IndexCastOp(T.index, _raw(kv_len_i32)).result

        head_group_idx = gpu.block_id("y")
        split_id = gpu.block_id("z")
        tid = gpu.thread_id("x")

        c_ws = arith.index(WARP_SIZE)
        wave_id = arith.DivUIOp(_raw(tid), _raw(c_ws)).result
        lane = arith.RemUIOp(_raw(tid), _raw(c_ws)).result

        c16 = arith.index(16)
        lane_mod_16 = arith.RemUIOp(_raw(lane), _raw(c16)).result
        lane_div_16 = arith.DivUIOp(_raw(lane), _raw(c16)).result

        lane_mod_16_x2 = lane_mod_16 * 2

        q_head_idx = head_group_idx * HEADS_PER_WAVE + lane_mod_16
        q_head_base = head_group_idx * HEADS_PER_WAVE
        c_gqa = arith.index(GQA_GROUP)
        kv_head_idx = arith.DivUIOp(_raw(q_head_base), _raw(c_gqa)).result

        kv_head_offset = kv_head_idx * HEAD_DIM_QK

        # ---- KV split range ----
        num_kv_splits_v = arith.index_cast(T.index, num_kv_splits.ir_value())
        c_bn_split = arith.index(BLOCK_N)
        c1_split = arith.index(1)
        total_kv_tiles = arith.DivUIOp(
            _raw(seqlen_kv_v), _raw(c_bn_split)).result
        tiles_nkv_m1 = arith.SubIOp(
            _raw(num_kv_splits_v), _raw(c1_split)).result
        tiles_plus = arith.AddIOp(
            _raw(total_kv_tiles), _raw(tiles_nkv_m1)).result
        tiles_per_split = arith.DivUIOp(
            _raw(tiles_plus), _raw(num_kv_splits_v)).result
        kv_per_split = tiles_per_split * BLOCK_N
        kv_split_start = split_id * kv_per_split
        kv_split_end = arith.MinUIOp(
            _raw(kv_split_start + kv_per_split),
            _raw(seqlen_kv_v),
        ).result

        # ---- Mid_O / Mid_lse strides ----
        stride_mid_o_token = num_kv_splits_v * (NUM_Q_HEADS * HEAD_DIM_V)
        stride_mid_lse_token = num_kv_splits_v * NUM_Q_HEADS

        # ---- V^T transpose decomposition ----
        c_128 = arith.index(128)
        tid_mod_128 = arith.RemUIOp(_raw(tid), _raw(c_128)).result
        tid_div_128 = arith.DivUIOp(_raw(tid), _raw(c_128)).result
        vt_dim_quad = tid_mod_128 * 4
        c_perm_lo = arith.constant(0x05040100, type=i32_type)
        c_perm_hi = arith.constant(0x07060302, type=i32_type)

        # ---- Global index helpers ----
        q_row = wave_id

        def q_global_idx(q_row_v, d_col):
            token = batch_idx * seqlen_q_v + q_row_v
            return (
                token * STRIDE_TOKEN_Q
                + q_head_idx * HEAD_DIM_QK
                + d_col
            )

        def mid_o_global_idx(q_row_v, d_col):
            total_q = batch_idx * seqlen_q_v + q_row_v
            return (
                total_q * stride_mid_o_token
                + split_id * (NUM_Q_HEADS * HEAD_DIM_V)
                + q_head_idx * HEAD_DIM_V
                + d_col
            )

        def mid_lse_global_idx(q_row_v):
            total_q = batch_idx * seqlen_q_v + q_row_v
            return (
                total_q * stride_mid_lse_token
                + split_id * NUM_Q_HEADS
                + q_head_idx
            )

        # ---- Block table lookup ----
        c_pbs = arith.index(PAGE_BLOCK_SIZE)
        max_log_block = arith.SubIOp(
            _raw(max_num_blocks_v), _raw(arith.index(1))).result

        def lookup_page(kv_abs_pos):
            log_block = arith.DivUIOp(
                _raw(kv_abs_pos), _raw(c_pbs)).result
            log_block = arith.MinUIOp(
                _raw(log_block), _raw(max_log_block)).result
            p_off = arith.RemUIOp(
                _raw(kv_abs_pos), _raw(c_pbs)).result
            bt_idx = batch_idx * max_num_blocks_v + log_block
            bt_byte_off = arith.index_cast(i32_type, bt_idx * 4)
            phys_i32 = rocdl.raw_ptr_buffer_load(
                i32_type, bt_rsrc, _raw(bt_byte_off),
                _raw(_bt_soff), _raw(_bt_aux),
            )
            phys = arith.index_cast(T.index, phys_i32)
            page_base = phys * STRIDE_PAGE
            return page_base, p_off

        bt_rsrc = buffer_ops.create_buffer_resource(block_table)
        _bt_aux = arith.constant(0, type=i32_type)
        _bt_base_i32 = arith.index_cast(
            i32_type, batch_idx * max_num_blocks_v)
        _c6_i32 = arith.constant(6, type=i32_type)
        _c2_i32 = arith.constant(2, type=i32_type)
        _bt_soff = arith.ShLIOp(
            _raw(_bt_base_i32), _raw(_c2_i32)).result
        _c_pbs_mask_i32 = arith.constant(
            PAGE_BLOCK_SIZE - 1, type=i32_type)

        def lookup_page_issue(kv_abs_pos, clamp=True, pos_i32=None):
            if clamp:
                p_off = arith.RemUIOp(
                    _raw(kv_abs_pos), _raw(c_pbs)).result
                log_block = arith.DivUIOp(
                    _raw(kv_abs_pos), _raw(c_pbs)).result
                log_block = arith.MinUIOp(
                    _raw(log_block), _raw(max_log_block)).result
                bt_byte_off = arith.index_cast(
                    i32_type, log_block * 4)
            else:
                if pos_i32 is None:
                    pos_i32 = arith.index_cast(
                        i32_type, kv_abs_pos)
                _and_res = arith.AndIOp(
                    _raw(pos_i32), _raw(_c_pbs_mask_i32)).result
                p_off = arith.IndexCastOp(
                    T.index, _raw(_and_res)).result
                log_block_i32 = arith.ShRUIOp(
                    _raw(pos_i32), _raw(_c6_i32)).result
                bt_byte_off = arith.ShLIOp(
                    _raw(log_block_i32), _raw(_c2_i32)).result
            phys_i32 = rocdl.raw_ptr_buffer_load(
                i32_type, bt_rsrc, _raw(bt_byte_off),
                _raw(_bt_soff), _raw(_bt_aux),
            )
            return phys_i32, p_off

        def lookup_page_resolve(phys_i32):
            phys = arith.index_cast(T.index, phys_i32)
            return phys * STRIDE_PAGE

        K_ROW_SOFFSETS = [
            arith.constant(r * STRIDE_TOKEN_KV * 2, type=i32_type)
            for r in range(K_ROWS_PER_WAVE)
        ]
        K_J_OFFSETS = [
            arith.constant(j * 2 * WARP_SIZE * 2, type=i32_type)
            for j in range(K_CALLS_PER_ROW)
        ]

        # ---- Cooperative K load: paged global -> K_buf (k_buf memref) ----
        def coop_load_k(kv_page_base, page_off, k_buf):
            g_f16_wave_row0 = (
                kv_page_base
                + (page_off + wave_id * K_ROWS_PER_WAVE)
                * STRIDE_TOKEN_KV
                + kv_head_offset
            )
            voff_base = g_f16_wave_row0 * 2 + lane * 4
            voff_base_i32 = arith.index_cast(i32_type, voff_base)

            lds_offset = wave_id * (K_ROWS_PER_WAVE * K_STRIDE * 2)
            lds_base_idx = memref_dialect.extract_aligned_pointer_as_index(
                k_buf)
            lds_base_i64 = arith.index_cast(T.i64, lds_base_idx)
            lds_base_lane0 = rocdl.readfirstlane(T.i64, _raw(lds_base_i64))
            lds_row0_i64 = lds_base_lane0 + arith.index_cast(T.i64, lds_offset)

            lds_ptr3_type = ir.Type.parse('!llvm.ptr<3>')
            for r_off in range_constexpr(K_ROWS_PER_WAVE):
                byte_off_val = r_off * (K_STRIDE * 2)
                if byte_off_val == 0:
                    lds_addr = lds_row0_i64
                else:
                    lds_addr = lds_row0_i64 + arith.constant(
                        byte_off_val, type=T.i64)
                lds_ptr = llvm.IntToPtrOp(
                    lds_ptr3_type, _raw(lds_addr)).result
                for j in range_constexpr(K_CALLS_PER_ROW):
                    rocdl.raw_ptr_buffer_load_lds(
                        kv_rsrc,
                        lds_ptr,
                        _raw(c_dword_sz),
                        _raw(voff_base_i32),
                        _raw(K_ROW_SOFFSETS[r_off]),
                        _raw(K_J_OFFSETS[j]),
                        _raw(aux),
                    )

        # ---- V transpose: K_buf(LDS) -> V^T_buf(LDS) ----
        v2i32_type = ir.VectorType.get([2], i32_type)

        def coop_load_v(k_buf):
            vt_read_base = tid_div_128 * (4 * K_STRIDE) + vt_dim_quad
            v_raw = []
            for g_pair in range_constexpr(BLOCK_N // 8):
                dwords_dp0 = []
                dwords_dp1 = []
                for s in range_constexpr(4):
                    lds_idx = vt_read_base + (g_pair * 8 + s) * K_STRIDE
                    quad = vector.load_op(v4f16_type, k_buf, [lds_idx])
                    dw_pair = vector.bitcast(v2i32_type, quad)
                    dwords_dp0.append(vector.extract(
                        dw_pair, static_position=[0], dynamic_position=[]))
                    dwords_dp1.append(vector.extract(
                        dw_pair, static_position=[1], dynamic_position=[]))
                v_raw.append((dwords_dp0, dwords_dp1))
            return v_raw

        def coop_perm_store_v(v_raw):
            vt_write_base = tid_mod_128 * (2 * VT_STRIDE) + tid_div_128 * 8
            for g_pair in range_constexpr(BLOCK_N // 8):
                dwords_dp0, dwords_dp1 = v_raw[g_pair]
                for dp_idx, dwords in enumerate([dwords_dp0, dwords_dp1]):
                    out = []
                    for src_pair, sel in [
                        ((1, 0), c_perm_lo), ((3, 2), c_perm_lo),
                        ((1, 0), c_perm_hi), ((3, 2), c_perm_hi),
                    ]:
                        dw = llvm.call_intrinsic(
                            i32_type, "llvm.amdgcn.perm",
                            [_raw(dwords[src_pair[0]]),
                             _raw(dwords[src_pair[1]]),
                             _raw(sel)],
                            [], [],
                        )
                        v1 = vector.from_elements(v1i32_type, [dw])
                        out.append(vector.bitcast(v2f16_type, v1))
                    v4_lo = _vec_shuffle(out[0], out[1], [0, 1, 2, 3])
                    v4_hi = _vec_shuffle(out[2], out[3], [0, 1, 2, 3])
                    vec = _vec_shuffle(
                        v4_lo, v4_hi, [0, 1, 2, 3, 4, 5, 6, 7])
                    vt_idx = (
                        vt_write_base + dp_idx * VT_STRIDE + g_pair * 16
                    )
                    vector.store(vec, lds_vt, [vt_idx])

        def coop_transpose_v_from_lds(k_buf):
            v_raw = coop_load_v(k_buf)
            coop_perm_store_v(v_raw)

        # ---- Preload Q ----
        c1_idx = arith.index(1)

        q_rsrc = buffer_ops.create_buffer_resource(Q)
        mid_o_rsrc = buffer_ops.create_buffer_resource(Mid_O)
        mid_lse_rsrc = buffer_ops.create_buffer_resource(Mid_lse)

        kv_total_blocks = batch_size_v * max_num_blocks_v
        kv_total_elems = kv_total_blocks * STRIDE_PAGE
        kv_size_bytes = kv_total_elems * 2
        c_max_records = arith.index(0x7FFFFFFE)
        kv_size_capped = arith.MinUIOp(
            _raw(kv_size_bytes), _raw(c_max_records)).result
        kv_rsrc = buffer_ops.create_buffer_resource(
            KV, num_records_bytes=kv_size_capped)
        lds_base_byte_idx = memref_dialect.extract_aligned_pointer_as_index(
            lds_k_cur_buf)
        c_dword_sz = arith.constant(4, type=i32_type)
        c_zero_i32 = arith.constant(0, type=i32_type)
        aux = arith.constant(1, type=i32_type)

        q_b_packs_lo = [None] * K_STEPS
        q_b_packs_hi = [None] * K_STEPS

        c32 = arith.index(32)
        lane_div_32 = arith.DivUIOp(_raw(lane), _raw(c32)).result
        lane_mod_32 = arith.RemUIOp(_raw(lane), _raw(c32)).result

        q_voff_base_f16 = (
            batch_idx * seqlen_q_v * STRIDE_TOKEN_Q
            + wave_id * STRIDE_TOKEN_Q
            + head_group_idx * (HEADS_PER_WAVE * HEAD_DIM_QK)
            + lane_div_32 * HEAD_DIM_QK
            + lane_mod_32 * 2
        )

        Q_LDS_PAIR_BYTES = 2 * Q_TILE_DIM * 2
        Q_GLOBAL_PAIR_BYTES = 2 * HEAD_DIM_QK * 2
        Q_CALL_SOFFSETS = [
            arith.constant(
                c * (Q_GLOBAL_PAIR_BYTES - Q_LDS_PAIR_BYTES),
                type=i32_type,
            )
            for c in range(Q_CALLS_PER_WAVE)
        ]
        Q_CALL_INST_OFFSETS = [
            arith.constant(c * Q_LDS_PAIR_BYTES, type=i32_type)
            for c in range(Q_CALLS_PER_WAVE)
        ]

        Q_TILE_BYTES = Q_TILE_ELEMS * 2

        pf0_phys_i32, pf0_p_off = lookup_page_issue(kv_split_start)
        tile1_start_early = kv_split_start + BLOCK_N
        pf1_phys_early, pf1_p_off_early = lookup_page_issue(
            tile1_start_early)

        d_tile_start = 0
        while const_expr(d_tile_start < Q_DIM_TILES):
            batch_size_q = min(Q_DIM_TILES - d_tile_start, Q_MAX_BATCH)

            for t in range_constexpr(batch_size_q):
                d_tile = d_tile_start + t

                tile_lds_byte = (
                    lds_base_byte_idx
                    + t * Q_TILE_BYTES
                    + wave_id * (HEADS_PER_WAVE * Q_TILE_DIM * 2)
                )
                tile_lds_i64 = arith.IndexCastOp(
                    T.i64, _raw(tile_lds_byte)).result
                tile_lds_scalar = rocdl.readfirstlane(
                    T.i64, _raw(tile_lds_i64))
                tile_lds_ptr = _create_llvm_ptr(
                    tile_lds_scalar, address_space=3)

                q_voff_byte = (q_voff_base_f16 + d_tile * Q_TILE_DIM) * 2
                q_voff_i32 = arith.index_cast(i32_type, q_voff_byte)

                for c in range_constexpr(Q_CALLS_PER_WAVE):
                    rocdl.raw_ptr_buffer_load_lds(
                        q_rsrc, tile_lds_ptr,
                        _raw(c_dword_sz),
                        _raw(q_voff_i32),
                        _raw(Q_CALL_SOFFSETS[c]),
                        _raw(Q_CALL_INST_OFFSETS[c]),
                        _raw(aux),
                    )

            _s_waitcnt(vmcnt=0)
            gpu.barrier()

            for t in range_constexpr(batch_size_q):
                d_tile = d_tile_start + t
                q_tile_byte_base = (
                    lds_base_byte_idx
                    + (arith.index(t * Q_TILE_ELEMS)
                       + (wave_id * HEADS_PER_WAVE + lane_mod_16)
                       * Q_TILE_DIM
                       + lane_div_16 * 8) * 2
                )
                q_tile_addr_i32 = arith.index_cast(
                    i32_type, q_tile_byte_base)
                for local_ks in range_constexpr(2):
                    global_ks = d_tile * 2 + local_ks
                    _base_off = local_ks * 64
                    _ds_128 = llvm.InlineAsmOp(
                        res=v8f16_type,
                        operands_=[_raw(q_tile_addr_i32)],
                        asm_string=(
                            f"ds_read_b128 $0, $1"
                            f" offset:{_base_off}"
                        ),
                        constraints="=a,v",
                        has_side_effects=True,
                        is_align_stack=False,
                    )
                    q_wide = _ds_128.result
                    q_b_packs_lo[global_ks] = _vec_shuffle(
                        q_wide, q_wide, [0, 1, 2, 3])
                    q_b_packs_hi[global_ks] = _vec_shuffle(
                        q_wide, q_wide, [4, 5, 6, 7])

            gpu.barrier()
            d_tile_start += batch_size_q

        # ---- Constants ----
        c_neg_inf = arith.constant(float("-inf"), type=compute_type)
        c_neg_large = arith.constant(-1e6, type=compute_type)
        c_zero_f = arith.constant(0.0, type=compute_type)
        c_one_f = arith.constant(1.0, type=compute_type)
        c_sm_scale = arith.constant(sm_scale, type=compute_type)
        c_log2e = arith.constant(1.4426950408889634, type=compute_type)
        c_zero_v4f32 = arith.constant_vector(0.0, v4f32_type)
        c0_idx = arith.index(0)
        c_kbuf = arith.index(K_BUF_ELEMS)

        N_DP = D_CHUNKS // 2

        def _vt_idx(dp):
            return (
                (dp * 16 + lane_mod_16) * VT_STRIDE
                + lane_div_16 * 8
            )

        def vgpr_pin(val):
            return llvm.InlineAsmOp(
                res=_raw(val).type,
                operands_=[_raw(val)],
                asm_string="; vgpr_pin",
                constraints="=v,0",
                has_side_effects=True,
                is_align_stack=False,
            ).result

        def softmax_and_pack(s_acc, m_old, l_old,
                             kv_pos=None, do_causal=False):
            s_vals = [None] * 4
            for ii in range_constexpr(4):
                s_val = vector.extract(
                    s_acc, static_position=[ii], dynamic_position=[])
                s_val = arith.MulFOp(
                    _raw(s_val), _raw(c_sm_scale),
                    fastmath=fm_fast).result
                if CAUSAL and do_causal:
                    kv_abs = kv_pos + lane_div_16 * 4 + ii
                    q_abs_pos = seqlen_kv_v - seqlen_q_v + q_row
                    kv_abs_i64 = arith.IndexCastOp(
                        T.i64, _raw(kv_abs)).result
                    q_abs_i64 = arith.IndexCastOp(
                        T.i64, _raw(q_abs_pos)).result
                    is_masked = arith.CmpIOp(
                        arith.CmpIPredicate.ugt,
                        _raw(kv_abs_i64), _raw(q_abs_i64),
                    ).result
                    s_val = arith.SelectOp(
                        _raw(is_masked),
                        _raw(c_neg_large), _raw(s_val),
                    ).result
                s_vals[ii] = s_val

            local_max = s_vals[0]
            for ii in range_constexpr(3):
                local_max = arith.MaximumFOp(
                    _raw(local_max), _raw(s_vals[ii + 1])).result

            red_wr_idx = wave_id * 64 + lane_mod_16 * 4 + lane_div_16
            memref_dialect.StoreOp(
                _raw(local_max), _raw(lds_red), [_raw(red_wr_idx)])
            _s_waitcnt(lgkmcnt=0)

            red_rd_base = wave_id * 64 + lane_mod_16 * 4
            max_vec = vector.load_op(
                v4f32_type, lds_red, [red_rd_base])
            global_max = c_neg_large
            for g in range_constexpr(4):
                max_g = vector.extract(
                    max_vec, static_position=[g], dynamic_position=[])
                global_max = arith.MaximumFOp(
                    _raw(global_max), _raw(max_g)).result
            _s_waitcnt(lgkmcnt=0)

            m_new = arith.MaximumFOp(
                _raw(m_old), _raw(global_max)).result

            m_diff = arith.SubFOp(
                _raw(m_old), _raw(m_new), fastmath=fm_fast).result
            m_diff_scaled = arith.MulFOp(
                _raw(m_diff), _raw(c_log2e), fastmath=fm_fast).result
            rescale = std_math.exp2(_raw(m_diff_scaled), fastmath=fm_fast)

            p_vals = [None] * 4
            local_sum = c_zero_f
            for ii in range_constexpr(4):
                diff = arith.SubFOp(
                    _raw(s_vals[ii]), _raw(m_new), fastmath=fm_fast).result
                diff_s = arith.MulFOp(
                    _raw(diff), _raw(c_log2e), fastmath=fm_fast).result
                p = std_math.exp2(_raw(diff_s), fastmath=fm_fast)
                p_vals[ii] = p
                local_sum = arith.AddFOp(
                    _raw(local_sum), _raw(p), fastmath=fm_fast).result

            l_scaled = arith.MulFOp(
                _raw(l_old), _raw(rescale), fastmath=fm_fast).result
            l_new = arith.AddFOp(
                _raw(l_scaled), _raw(local_sum), fastmath=fm_fast).result

            p_f16 = []
            for ii in range_constexpr(4):
                p_f16.append(arith.TruncFOp(
                    elem_type, _raw(p_vals[ii])).result)
            p_pack = vector.from_elements(v4f16_type, p_f16)
            return m_new, l_new, p_pack, rescale

        def rescale_o_accs(o_accs, rescale):
            rescale_i32 = arith.BitcastOp(
                i32_type, _raw(rescale)).result
            rescale_sgpr = rocdl.readfirstlane(i32_type, _raw(rescale_i32))
            rescale_dup = arith.BitcastOp(
                compute_type, _raw(rescale_sgpr)).result
            rescale_vec = vector.from_elements(
                v4f32_type,
                [rescale, rescale_dup, rescale, rescale_dup])
            for dc in range_constexpr(D_CHUNKS):
                o_accs[dc] = arith.MulFOp(
                    _raw(o_accs[dc]), _raw(rescale_vec),
                    fastmath=fm_fast).result

        def do_kv_tile(kv_pos, m_old, l_old, o_accs,
                       k_cur_buf, k_next_buf, k_buf,
                       load_knn=True, do_vt=True,
                       do_causal=False):
            rocdl.sched_barrier(0)

            if load_knn:
                nn_start = kv_pos + 2 * BLOCK_N
                nn_phys_i32, nn_p_off = lookup_page_issue(nn_start)

            # ==== GEMM1: S = K @ Q^T ====
            s_accs = [c_zero_v4f32]
            v_buf = [None] * N_DP
            for ks in range_constexpr(K_STEPS):
                if ks < N_DP:
                    v_buf[ks] = vector.load_op(
                        v8f16_type, lds_vt, [_vt_idx(ks)])
                q_lo = q_b_packs_lo[ks]
                q_hi = q_b_packs_hi[ks]
                k_lo = _vec_shuffle(
                    k_buf[ks], k_buf[ks], [0, 1, 2, 3])
                k_hi = _vec_shuffle(
                    k_buf[ks], k_buf[ks], [4, 5, 6, 7])
                s_accs[0] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [k_lo, q_lo, s_accs[0], 0, 0, 0],
                )
                s_accs[0] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [k_hi, q_hi, s_accs[0], 0, 0, 0],
                )

            if load_knn:
                nn_page_base = lookup_page_resolve(nn_phys_i32)
                coop_load_k(nn_page_base, nn_p_off, k_cur_buf)

            rocdl.sched_barrier(0)

            # ==== Softmax + P pack ====
            m_new, l_new, p_pack, rescale = softmax_and_pack(
                s_accs[0], m_old, l_old,
                kv_pos=kv_pos, do_causal=do_causal,
            )
            rescale_o_accs(o_accs, rescale)

            # ==== GEMM2: O^T = V^T @ P ====
            k_next_base_idx = (
                lane_mod_16 * K_STRIDE + lane_div_16 * 8
            )
            k_buf_next = [None] * K_STEPS
            EXTRA_K = K_STEPS - N_DP
            k_block = 0
            for dp in range_constexpr(N_DP):
                k_next_idx = k_next_base_idx + k_block * 32
                k_buf_next[k_block] = vector.load_op(
                    v8f16_type, k_next_buf, [k_next_idx])
                k_block += 1
                if dp < EXTRA_K:
                    k_extra_idx = k_next_base_idx + k_block * 32
                    k_buf_next[k_block] = vector.load_op(
                        v8f16_type, k_next_buf, [k_extra_idx])
                    k_block += 1
                v_lo = _vec_shuffle(
                    v_buf[dp], v_buf[dp], [0, 1, 2, 3])
                v_hi = _vec_shuffle(
                    v_buf[dp], v_buf[dp], [4, 5, 6, 7])
                o_accs[dp * 2] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [v_lo, p_pack, o_accs[dp * 2], 0, 0, 0],
                )
                o_accs[dp * 2 + 1] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [v_hi, p_pack, o_accs[dp * 2 + 1], 0, 0, 0],
                )

            if do_vt:
                coop_transpose_v_from_lds(k_next_buf)

            return m_new, l_new, o_accs, k_buf_next

        def do_kv_pair(kv_pos, m_old, l_old, o_accs,
                       k_cur_buf, k_next_buf, k_buf_a,
                       nn_a_phys_in=None,
                       load_knn=True, do_vt_final=True):
            rocdl.sched_barrier(0)

            nn_a_phys_next = None
            if load_knn:
                nn_a_phys = nn_a_phys_in
                kv_pos_i32 = arith.index_cast(i32_type, kv_pos)
                c_2bn_i32 = arith.constant(2 * BLOCK_N, type=i32_type)
                c_3bn_i32 = arith.constant(3 * BLOCK_N, type=i32_type)
                c_4bn_i32 = arith.constant(4 * BLOCK_N, type=i32_type)
                nn_a_pos_i32 = arith.AddIOp(
                    _raw(kv_pos_i32), _raw(c_2bn_i32)).result
                _nn_a_and = arith.AndIOp(
                    _raw(nn_a_pos_i32), _raw(_c_pbs_mask_i32)).result
                nn_a_poff = arith.IndexCastOp(
                    T.index, _raw(_nn_a_and)).result
                nn_b_pos_i32 = arith.AddIOp(
                    _raw(kv_pos_i32), _raw(c_3bn_i32)).result
                nn_b_phys, nn_b_poff = lookup_page_issue(
                    None, clamp=False, pos_i32=nn_b_pos_i32)
                _c4_i32 = arith.constant(4, type=i32_type)
                kv_block_i32 = arith.ShRUIOp(
                    _raw(kv_pos_i32), _raw(_c6_i32)).result
                kv_block_byte = arith.ShLIOp(
                    _raw(kv_block_i32), _raw(_c2_i32)).result
                nn_a_next_byte = arith.AddIOp(
                    _raw(kv_block_byte), _raw(_c4_i32)).result
                nn_a_phys_next = rocdl.raw_ptr_buffer_load(
                    i32_type, bt_rsrc, _raw(nn_a_next_byte),
                    _raw(_bt_soff), _raw(_bt_aux),
                )

            if load_knn:
                nn_a_base = lookup_page_resolve(nn_a_phys)
                coop_load_k(nn_a_base, nn_a_poff, k_cur_buf)

            # ============ TILE A ============
            s_a = [c_zero_v4f32]
            v_buf_a = [None] * N_DP
            for ks in range_constexpr(K_STEPS):
                if ks < N_DP:
                    v_buf_a[ks] = vector.load_op(
                        v8f16_type, lds_vt, [_vt_idx(ks)])
                q_lo = q_b_packs_lo[ks]
                q_hi = q_b_packs_hi[ks]
                k_lo = _vec_shuffle(
                    k_buf_a[ks], k_buf_a[ks], [0, 1, 2, 3])
                k_hi = _vec_shuffle(
                    k_buf_a[ks], k_buf_a[ks], [4, 5, 6, 7])
                s_a[0] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [k_lo, q_lo, s_a[0], 0, 0, 0],
                )
                s_a[0] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [k_hi, q_hi, s_a[0], 0, 0, 0],
                )

            rocdl.sched_barrier(0)
            m_a, l_a, p_pack_a, rescale_a = softmax_and_pack(
                s_a[0], m_old, l_old)
            rescale_o_accs(o_accs, rescale_a)
            rocdl.sched_barrier(0)

            v_raw_b = coop_load_v(k_next_buf)

            # GEMM2_A
            k_b_base = lane_mod_16 * K_STRIDE + lane_div_16 * 8
            k_buf_b = [None] * K_STEPS
            EXTRA_K = K_STEPS - N_DP
            k_block = 0
            for dp in range_constexpr(N_DP):
                k_b_idx = k_b_base + k_block * 32
                k_buf_b[k_block] = vector.load_op(
                    v8f16_type, k_next_buf, [k_b_idx])
                k_block += 1
                if dp < EXTRA_K:
                    k_b_extra = k_b_base + k_block * 32
                    k_buf_b[k_block] = vector.load_op(
                        v8f16_type, k_next_buf, [k_b_extra])
                    k_block += 1

                v_lo = _vec_shuffle(
                    v_buf_a[dp], v_buf_a[dp], [0, 1, 2, 3])
                v_hi = _vec_shuffle(
                    v_buf_a[dp], v_buf_a[dp], [4, 5, 6, 7])
                o_accs[dp * 2] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [v_lo, p_pack_a, o_accs[dp * 2], 0, 0, 0],
                )
                o_accs[dp * 2 + 1] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [v_hi, p_pack_a, o_accs[dp * 2 + 1], 0, 0, 0],
                )

            coop_perm_store_v(v_raw_b)
            rocdl.sched_barrier(0)

            # ============ TILE B ============
            if load_knn:
                nn_b_base = lookup_page_resolve(nn_b_phys)
                coop_load_k(nn_b_base, nn_b_poff, k_next_buf)

            s_b = [c_zero_v4f32]
            v_buf_b = [None] * N_DP
            for ks in range_constexpr(K_STEPS):
                if ks < N_DP:
                    v_buf_b[ks] = vector.load_op(
                        v8f16_type, lds_vt, [_vt_idx(ks)])
                q_lo = q_b_packs_lo[ks]
                q_hi = q_b_packs_hi[ks]
                k_lo = _vec_shuffle(
                    k_buf_b[ks], k_buf_b[ks], [0, 1, 2, 3])
                k_hi = _vec_shuffle(
                    k_buf_b[ks], k_buf_b[ks], [4, 5, 6, 7])
                s_b[0] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [k_lo, q_lo, s_b[0], 0, 0, 0],
                )
                s_b[0] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [k_hi, q_hi, s_b[0], 0, 0, 0],
                )

            rocdl.sched_barrier(0)
            m_b, l_b, p_pack_b, rescale_b = softmax_and_pack(
                s_b[0], m_a, l_a)
            if do_vt_final:
                v_raw_next = coop_load_v(k_cur_buf)
            rescale_o_accs(o_accs, rescale_b)
            rocdl.sched_barrier(0)

            # GEMM2_B
            k_nn_base = lane_mod_16 * K_STRIDE + lane_div_16 * 8
            k_block = 0
            for dp in range_constexpr(N_DP):
                k_nn_idx = k_nn_base + k_block * 32
                k_buf_a[k_block] = vector.load_op(
                    v8f16_type, k_cur_buf, [k_nn_idx])
                k_block += 1
                if dp < EXTRA_K:
                    k_nn_extra = k_nn_base + k_block * 32
                    k_buf_a[k_block] = vector.load_op(
                        v8f16_type, k_cur_buf, [k_nn_extra])
                    k_block += 1

                v_lo = _vec_shuffle(
                    v_buf_b[dp], v_buf_b[dp], [0, 1, 2, 3])
                v_hi = _vec_shuffle(
                    v_buf_b[dp], v_buf_b[dp], [4, 5, 6, 7])
                o_accs[dp * 2] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [v_lo, p_pack_b, o_accs[dp * 2], 0, 0, 0],
                )
                o_accs[dp * 2 + 1] = rocdl.mfma_f32_16x16x16f16(
                    v4f32_type,
                    [v_hi, p_pack_b, o_accs[dp * 2 + 1], 0, 0, 0],
                )

            if do_vt_final:
                coop_perm_store_v(v_raw_next)

            if nn_a_phys_next is not None:
                nn_a_phys_next = rocdl.readfirstlane(
                    i32_type, _raw(nn_a_phys_next))
            return (m_b, l_b, o_accs, k_buf_a, nn_a_phys_next)

        has_kv_work = arith.CmpIOp(
            arith.CmpIPredicate.ult,
            _raw(kv_split_start), _raw(kv_split_end),
        ).result

        # ---- Pre-loop: double-prefetch K tiles 0 and 1 ----
        page_base_0 = lookup_page_resolve(pf0_phys_i32)
        coop_load_k(page_base_0, pf0_p_off, lds_k_cur_buf)

        page_base_1 = lookup_page_resolve(pf1_phys_early)
        coop_load_k(page_base_1, pf1_p_off_early, lds_k_next_buf)
        _s_waitcnt(vmcnt=20)

        coop_transpose_v_from_lds(lds_k_cur_buf)
        rocdl.sched_barrier(0)

        # Prologue: pre-load all K[0] from LDS into AGPRs
        k_base_idx_init = lane_mod_16 * K_STRIDE + lane_div_16 * 8
        k_byte_base = lds_base_byte_idx + k_base_idx_init * 2
        k_byte_base_i32 = arith.index_cast(i32_type, k_byte_base)
        k_buf_init = []
        for ks in range_constexpr(K_STEPS):
            _off = ks * 64
            _ds_k = llvm.InlineAsmOp(
                res=v8f16_type,
                operands_=[_raw(k_byte_base_i32)],
                asm_string=(
                    f"ds_read_b128 $0, $1 offset:{_off}"
                ),
                constraints="=a,v",
                has_side_effects=True,
                is_align_stack=False,
            )
            k_buf_init.append(_ds_k.result)

        if has_kv_work:
            o_accs_init = [
                arith.constant_vector(0.0, v4f32_type)
                for _ in range_constexpr(D_CHUNKS)
            ]
            m_init = c_neg_large
            l_init = c_zero_f

            three_tiles_end = kv_split_start + 3 * BLOCK_N
            has_three = arith.CmpIOp(
                arith.CmpIPredicate.ule,
                _raw(three_tiles_end), _raw(kv_split_end),
            ).result
            body_end = arith.SelectOp(
                _raw(has_three),
                _raw(kv_split_end - 2 * BLOCK_N),
                _raw(kv_split_start),
            ).result

            four_tiles = kv_split_start + 4 * BLOCK_N
            has_four = arith.CmpIOp(
                arith.CmpIPredicate.ule,
                _raw(four_tiles), _raw(kv_split_end),
            ).result
            pair_ub = arith.SelectOp(
                _raw(has_four),
                _raw(kv_split_end - 3 * BLOCK_N),
                _raw(kv_split_start),
            ).result

            rocdl.sched_barrier(0)

            nn_a_pf_start = kv_split_start + 2 * BLOCK_N
            nn_a_pf_phys_v, _ = lookup_page_issue(nn_a_pf_start)
            nn_a_pf_phys = rocdl.readfirstlane(
                i32_type, _raw(nn_a_pf_phys_v))

            _PKB = 5 + D_CHUNKS
            _PNN = _PKB + K_STEPS
            pair_init = (
                [kv_split_start, m_init, l_init]
                + o_accs_init
                + [lds_k_cur_buf, lds_k_next_buf]
                + k_buf_init
                + [nn_a_pf_phys]
            )
            for pair_pos, state in range(
                kv_split_start, pair_ub, 2 * BLOCK_N, init=pair_init
            ):
                m_pair = state[1]
                l_pair = state[2]
                o_pair = [state[3 + dc] for dc in range_constexpr(D_CHUNKS)]
                k_pair_cur = state[3 + D_CHUNKS]
                k_pair_next = state[4 + D_CHUNKS]
                k_pair_buf = [
                    state[_PKB + ks] for ks in range_constexpr(K_STEPS)
                ]
                nn_a_p_in = state[_PNN]

                (m_pr, l_pr, o_pr, kbuf_pr, nn_a_p_out) = do_kv_pair(
                    pair_pos, m_pair, l_pair, o_pair,
                    k_pair_cur, k_pair_next,
                    k_pair_buf, nn_a_p_in,
                )
                next_pp = pair_pos + 2 * BLOCK_N
                pair_results = yield (
                    [next_pp, m_pr, l_pr] + o_pr
                    + [k_pair_cur, k_pair_next]
                    + kbuf_pr + [nn_a_p_out]
                )

            pair_end = pair_results[0]
            m_from_pair = pair_results[1]
            l_from_pair = pair_results[2]
            o_from_pair = [
                pair_results[3 + dc]
                for dc in range_constexpr(D_CHUNKS)
            ]
            k_pc = pair_results[3 + D_CHUNKS]
            k_pn = pair_results[4 + D_CHUNKS]
            kbuf_fp = [
                pair_results[_PKB + ks]
                for ks in range_constexpr(K_STEPS)
            ]

            # -- Single-tile body: remainder after pairs --
            _KB = 4 + D_CHUNKS
            body_init = (
                [m_from_pair, l_from_pair] + o_from_pair
                + [k_pc, k_pn] + kbuf_fp
            )
            for kv_pos, state in range(
                pair_end, body_end, BLOCK_N, init=body_init
            ):
                m_running = state[0]
                l_running = state[1]
                o_accs = [state[2 + dc] for dc in range_constexpr(D_CHUNKS)]
                k_cur_buf_l = state[2 + D_CHUNKS]
                k_next_buf_l = state[3 + D_CHUNKS]
                k_buf_loop = [
                    state[_KB + ks] for ks in range_constexpr(K_STEPS)
                ]

                m_new, l_new, o_accs, k_buf_new = do_kv_tile(
                    kv_pos, m_running, l_running, o_accs,
                    k_cur_buf_l, k_next_buf_l, k_buf_loop,
                )
                body_results = yield (
                    [m_new, l_new] + o_accs
                    + [k_next_buf_l, k_cur_buf_l] + k_buf_new
                )

            m_body = body_results[0]
            l_body = body_results[1]
            o_body = [
                body_results[2 + dc]
                for dc in range_constexpr(D_CHUNKS)
            ]
            k_body_cur = body_results[2 + D_CHUNKS]
            k_body_next = body_results[3 + D_CHUNKS]
            k_buf_body = [
                body_results[_KB + ks]
                for ks in range_constexpr(K_STEPS)
            ]

            # -- Penultimate tile --
            two_tiles_end = kv_split_start + 2 * BLOCK_N
            has_two = arith.CmpIOp(
                arith.CmpIPredicate.ule,
                _raw(two_tiles_end), _raw(kv_split_end),
            ).result
            penult_ub = arith.SelectOp(
                _raw(has_two),
                _raw(kv_split_end - BLOCK_N),
                _raw(body_end),
            ).result
            penult_init = (
                [m_body, l_body] + o_body
                + [k_body_cur, k_body_next] + k_buf_body
            )
            for kv_pos_p, state in range(
                body_end, penult_ub, BLOCK_N, init=penult_init
            ):
                m_p = state[0]
                l_p = state[1]
                o_p = [state[2 + dc] for dc in range_constexpr(D_CHUNKS)]
                k_p_cur = state[2 + D_CHUNKS]
                k_p_next = state[3 + D_CHUNKS]
                k_buf_p = [
                    state[_KB + ks] for ks in range_constexpr(K_STEPS)
                ]

                m_pn, l_pn, o_pn, k_buf_pn = do_kv_tile(
                    kv_pos_p, m_p, l_p, o_p,
                    k_p_cur, k_p_next, k_buf_p,
                    load_knn=False, do_vt=True,
                )
                penult_results = yield (
                    [m_pn, l_pn] + o_pn
                    + [k_p_next, k_p_cur] + k_buf_pn
                )

            m_penult = penult_results[0]
            l_penult = penult_results[1]
            o_penult = [
                penult_results[2 + dc]
                for dc in range_constexpr(D_CHUNKS)
            ]
            k_last_cur = penult_results[2 + D_CHUNKS]
            k_last_next = penult_results[3 + D_CHUNKS]
            k_buf_last = [
                penult_results[_KB + ks]
                for ks in range_constexpr(K_STEPS)
            ]

            # -- Last tile --
            last_init = (
                [m_penult, l_penult] + o_penult
                + [k_last_cur, k_last_next] + k_buf_last
            )
            for kv_pos_l, state in range(
                penult_ub, kv_split_end, BLOCK_N, init=last_init
            ):
                m_l = state[0]
                l_l = state[1]
                o_l = [state[2 + dc] for dc in range_constexpr(D_CHUNKS)]
                k_l_cur = state[2 + D_CHUNKS]
                k_l_next = state[3 + D_CHUNKS]
                k_buf_l = [
                    state[_KB + ks] for ks in range_constexpr(K_STEPS)
                ]

                m_ln, l_ln, o_ln, k_buf_ln = do_kv_tile(
                    kv_pos_l, m_l, l_l, o_l,
                    k_l_cur, k_l_next, k_buf_l,
                    load_knn=False, do_vt=False,
                    do_causal=True,
                )
                last_results = yield (
                    [m_ln, l_ln] + o_ln
                    + [k_l_next, k_l_cur] + k_buf_ln
                )

            m_final = last_results[0]
            l_partial = last_results[1]
            o_finals = [
                last_results[2 + dc]
                for dc in range_constexpr(D_CHUNKS)
            ]

            # Cross-group l reduction via LDS
            red_wr_idx_epi = (
                wave_id * 64 + lane_mod_16 * 4 + lane_div_16
            )
            memref_dialect.StoreOp(
                _raw(l_partial), _raw(lds_red), [_raw(red_wr_idx_epi)])
            _s_waitcnt(lgkmcnt=0)

            red_rd_base_epi = wave_id * 64 + lane_mod_16 * 4
            l_vec = vector.load_op(
                v4f32_type, lds_red, [red_rd_base_epi])
            l_final = c_zero_f
            for g in range_constexpr(4):
                l_g = vector.extract(
                    l_vec, static_position=[g], dynamic_position=[])
                l_final = arith.AddFOp(
                    _raw(l_final), _raw(l_g), fastmath=fm_fast).result
            _s_waitcnt(lgkmcnt=0)

            l_gt_zero = arith.CmpFOp(
                arith.CmpFPredicate.OGT,
                _raw(l_final), _raw(c_zero_f),
            ).result
            safe_inv_l = arith.SelectOp(
                _raw(l_gt_zero),
                _raw(arith.DivFOp(
                    _raw(c_one_f), _raw(l_final),
                    fastmath=fm_fast).result),
                _raw(c_zero_f),
            ).result
            inv_l_vec = _vec_broadcast(v4f32_type, safe_inv_l)

            for dc in range_constexpr(D_CHUNKS):
                o_norm = arith.MulFOp(
                    _raw(o_finals[dc]), _raw(inv_l_vec),
                    fastmath=fm_fast).result
                for ii in range_constexpr(4):
                    o_val = vector.extract(
                        o_norm, static_position=[ii],
                        dynamic_position=[])
                    d_col = (
                        arith.index((dc // 2) * 32 + dc % 2)
                        + lane_div_16 * 8 + ii * 2
                    )
                    o_g_idx = mid_o_global_idx(q_row, d_col)
                    o_g_idx_i32 = arith.index_cast(i32_type, o_g_idx)
                    buffer_ops.buffer_store(
                        _raw(o_val), mid_o_rsrc, _raw(o_g_idx_i32))

            # lse = m + log(l)
            log_l = std_math.log(_raw(l_final), fastmath=fm_fast)
            lse_val = arith.AddFOp(
                _raw(m_final), _raw(log_l), fastmath=fm_fast).result
            lse_idx = mid_lse_global_idx(q_row)
            lse_idx_i32 = arith.index_cast(i32_type, lse_idx)
            buffer_ops.buffer_store(
                _raw(lse_val), mid_lse_rsrc, _raw(lse_idx_i32))

    # ---- Host launcher ----
    @flyc.jit
    def launch_mla_decode(
        Q: fx.Tensor,
        KV: fx.Tensor,
        Mid_O: fx.Tensor,
        Mid_lse: fx.Tensor,
        block_table: fx.Tensor,
        batch_size: fx.Int32,
        seqlen_q: fx.Int32,
        kv_indptr: fx.Tensor,
        max_num_blocks: fx.Int32,
        num_kv_splits: fx.Int32,
        stream: fx.Stream,
    ):
        allocator_pong.finalized = False
        allocator_ping.finalized = False
        allocator_vt.finalized = False
        allocator_red.finalized = False
        ctx = CompilationContext.get_current()
        with ir.InsertionPoint(ctx.gpu_module_body):
            allocator_pong.finalize()
            allocator_ping.finalize()
            allocator_vt.finalize()
            allocator_red.finalize()

        gx = _raw(arith.index_cast(T.index, batch_size.ir_value()))
        gy = _raw(arith.index(NUM_HEAD_GROUPS))
        gz = _raw(arith.index_cast(T.index, num_kv_splits.ir_value()))

        mla_decode_kernel(
            Q, KV, Mid_O, Mid_lse, block_table,
            batch_size, seqlen_q, kv_indptr, max_num_blocks, num_kv_splits,
        ).launch(
            grid=(gx, gy, gz),
            block=(BLOCK_SIZE, 1, 1),
            stream=stream,
        )

    return launch_mla_decode
